@{
    ViewBag.Title = "Session courante";

    string session = ViewBag.Session;
    int year = (int)ViewBag.Year;
    bool automnCheck = session == "Automne";
}

<div class="form-container">
    <form action="/CurrentSession/Edit" method="post">
        <div style="color:dodgerblue;font-size:1.0em;">
            Choisissez l'année et la session pour les prochaines allocations de cours :
        </div>

        <hr />

        <label for="year">Année</label>
        <input type="number"
               min="1990"
               max="@DateTime.Now.Year"
               value="@year"
               class="form-control"
               name="year"
               id="year" />

        <fieldset class="mt-3">
            <legend>Session</legend>

            <div style="display:grid; grid-template-columns:20px auto; align-items:center; gap:8px;">
                <input type="radio"
                       name="session"
                       value="Automne"
                       id="session_automne"
                       @(automnCheck ? "checked" : "") />
                <label for="session_automne">Automne</label>

                <input type="radio"
                       name="session"
                       value="Hiver"
                       id="session_hiver"
                       @(!automnCheck ? "checked" : "") />
                <label for="session_hiver">Hiver</label>
            </div>
        </fieldset>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">
                Confirmer
            </button>

            <a href="/Students/Index" class="btn btn-secondary">
                Annuler
            </a>
        </div>
    </form>
</div>