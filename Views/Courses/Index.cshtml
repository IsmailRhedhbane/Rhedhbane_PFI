@{
    ViewBag.Title = "Cours";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string searchString = (Session["CourseSearchString"] ?? "").ToString();
}

<div class="searchBar">
    <input type="text"
           id="courseSearchString"
           value="@searchString"
           placeholder="Recherche..." />
</div>

<div id="coursesPanel"></div>

@section Scripts {
    <script>
        let coursesPanel = null;

        function highlightCourseSearch() {
            let text = $("#courseSearchString").val();

            if (text != undefined && text.length > 0) {
                $(".courseCode, .courseTitle").each(function () {
                    highlight(text, this);
                });
            }
        }

        function setCourseSearch() {
            $.ajax({
                url: "@Url.Action("SetSearch", "Courses")",
                type: "GET",
                data: {
                    searchString: $("#courseSearchString").val()
                },
                success: function () {
                    coursesPanel.refresh();
                }
            });
        }

        $("#courseSearchString").on("keyup", function () {
            setCourseSearch();
        });

        coursesPanel = new AutoRefreshedPanel(
            "coursesPanel",
            "@Url.Action("GetCourses", "Courses")",
            5,
            highlightCourseSearch
        );
    </script>
}